# --- Database ----------------------------------------------------------------
# Postgres for production. SQLite is fine for local dev and is what tests use.
DATABASE_URL=postgresql+psycopg2://promosensei:promosensei@localhost:5432/promosensei
# DATABASE_URL=sqlite+pysqlite:///./promosensei.db

# --- Scrapers (Phase 3) ------------------------------------------------------
SCRAPER_AMAZON_DEALS_URL=https://www.amazon.in/deals
SCRAPER_FLIPKART_DEALS_URL=https://www.flipkart.com/offers-store
SCRAPER_NYKAA_DEALS_URL=https://www.nykaa.com/sp/offer-zone
SCRAPER_MAX_PAGES=5
SCRAPER_PAGE_TIMEOUT_MS=30000
SCRAPER_USE_FIXTURES=false
SCRAPER_SCHEDULE_HOURS=6
SCRAPER_FLIPKART_SCHEDULE_HOURS=6
SCRAPER_NYKAA_SCHEDULE_HOURS=12

# Window over which /health/scrapers computes per-platform success rate.
HEALTH_WINDOW_DAYS=30

# --- API ---------------------------------------------------------------------
API_CORS_ORIGINS=["http://localhost:3000"]
ENABLE_SCHEDULER=true

# --- Embeddings (Phase 2) ----------------------------------------------------
# Provider for product + query embeddings.
#   hashing               — zero-dep deterministic hashing trick. Default.
#   sentence-transformers — local MiniLM model. `pip install sentence-transformers`.
#   openai                — text-embedding-3-small. Requires OPENAI_API_KEY.
EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL=hashing-v1
EMBEDDING_DIM=256
EMBEDDING_BATCH_SIZE=64
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Indexer (Phase 2) -------------------------------------------------------
INDEXER_SCHEDULE_MINUTES=30

# --- Search defaults (Phase 2) ----------------------------------------------
# keyword | semantic | hybrid
SEARCH_DEFAULT_MODE=semantic
SEARCH_TOP_K=200
RANK_W_SIMILARITY=0.6
RANK_W_DISCOUNT=0.2
RANK_W_RATING=0.2

# --- Phase 4: caching --------------------------------------------------------
# memory (default, in-process LRU+TTL) | redis | none
CACHE_PROVIDER=memory
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=1024
CACHE_REDIS_URL=redis://localhost:6379/0

# --- Phase 4: incremental price refresh -------------------------------------
PRICE_REFRESH_MINUTES=30
PRICE_REFRESH_MAX_AGE_HOURS=6
PRICE_REFRESH_BATCH_SIZE=200

# --- Phase 4: scraper resilience --------------------------------------------
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_RETRY_BASE_DELAY_SECONDS=1.0
SCRAPER_RETRY_MAX_DELAY_SECONDS=30.0
BREAKER_FAILURE_THRESHOLD=3
BREAKER_COOLDOWN_SECONDS=600

# --- Phase 4: observability --------------------------------------------------
# json (production) | text (local dev)
LOG_FORMAT=json
LOG_LEVEL=INFO
METRICS_ENABLED=true

# --- Phase 4: ranking eval thresholds (CI gate) -----------------------------
EVAL_MIN_NDCG_AT_5=0.8
EVAL_MIN_PRECISION_AT_3=0.4
